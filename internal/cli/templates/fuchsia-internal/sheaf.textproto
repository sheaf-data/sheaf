version: 1
project { name: "fuchsia" display_name: "Fuchsia OS" }

scope {
  library: "fuchsia.io"
  closure { mode: LAZY max_depth: 2 external_policy: REFERENCE_ONLY }
}

contract_anchor {
  name: "fidl"
  fidl { include: "sdk/fidl/**/*.fidl" exclude: "sdk/fidl/**/test/**" }
}

test_parser {
  name: "gtest"
  gtest {
    include: "src/storage/lib/vfs/cpp/**/*_test.cc"
    include: "src/storage/lib/vfs/cpp/**/*_tests.cc"
  }
}
test_parser { name: "rust-test" rust_test { include: "src/**/*.rs" exclude: "**/target/**" } }
doc_parser  { name: "markdown"  markdown  { include: "docs/**/*.md" } }

implements_map {
  name: "cpp-fidl-wireserver"
  include: "src/storage/lib/vfs/cpp/**/*.h"
  include: "src/storage/lib/vfs/cpp/**/*.cc"
}

analyzer { name: "missing-in-category" severity: WARNING
  config { key: "alert_for_categories" string_value: "tests.unit_tests" }
}
analyzer { name: "thin-reference"      severity: WARNING }
analyzer { name: "documented-untested" severity: WARNING }
analyzer { name: "tested-undocumented" severity: INFO }

mcp_server { bind: "127.0.0.1" port: 7700 cache_ttl_seconds: 3600 }
cache      { store: "filesystem" filesystem { path: "~/.sheaf/cache" } }

llm {
  client: "local-llama"
  local_llama { host: "127.0.0.1" port: 11434 model: "qwen2.5:7b-instruct" }
  embeddings: "ollama-embed"
  ollama_embeddings { host: "127.0.0.1" port: 11434 model: "nomic-embed-text" }
}
