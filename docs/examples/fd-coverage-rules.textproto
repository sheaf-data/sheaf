# Source map for the fd CLI scan.
#
# fd is a single-binary tool — no subcommand hierarchy — so all 48
# contract elements are flags / switches / positionals under one
# command. We bucket them by the section headings fd's own --help
# output uses, so the rendered report's worklist mirrors what a
# reader sees in `fd --help`.
#
# Patterns match on the element ID ("fd --no-ignore", "fd --hidden",
# "fd <pattern>") emitted by the clap adapter. The default
# "flags.misc" bucket catches anything unmatched.

version: 1

category { dotted_path: "flags.misc" }

# README.md and CHANGELOG.md route to docs.concepts. The
# section_excludes filter drops flag-mentions that sit inside
# reference-shaped headings (the README's "Command-line options"
# table is essentially a copy of `--help`, so flag mentions there
# are reference material, not conceptual writing about pattern
# syntax or ignore-file handling). The categorizer matches each
# heading in a claim's section_path case-insensitively as a
# substring against these patterns.
category {
  dotted_path: "docs.concepts"
  paths: "README.md"
  paths: "CHANGELOG.md"
  section_excludes: "command-line options"
  section_excludes: "options"
  section_excludes: "synopsis"
  section_excludes: "usage"
  section_excludes: "installation"
}

# ---- Ignore-file & hidden behavior --------------------------------
# The .gitignore/.fdignore/.hidden cluster — what fd shows or skips
# by default. Most-used flags after the positional pattern.
category {
  dotted_path: "flags.ignore-and-hidden"
  paths: "fd --hidden"
  paths: "fd --no-ignore"
  paths: "fd --no-ignore-vcs"
  paths: "fd --no-require-git"
  paths: "fd --no-ignore-parent"
  paths: "fd --no-global-ignore-file"
  paths: "fd --unrestricted"
  paths: "fd --ignore-file"
}

# ---- Search syntax / matching mode --------------------------------
# Regex vs glob vs literal, case sensitivity, full-path matching.
category {
  dotted_path: "flags.search-mode"
  paths: "fd --case-sensitive"
  paths: "fd --ignore-case"
  paths: "fd --glob"
  paths: "fd --regex"
  paths: "fd --fixed-strings"
  paths: "fd --exact"
  paths: "fd --and"
  paths: "fd --full-path"
}

# ---- Filters (type / extension / size / time / owner) -------------
category {
  dotted_path: "flags.filters"
  paths: "fd --type"
  paths: "fd --extension"
  paths: "fd --size"
  paths: "fd --changed-within"
  paths: "fd --changed-before"
  paths: "fd --owner"
  paths: "fd --exclude"
  paths: "fd --prune"
  paths: "fd --ignore-contain"
}

# ---- Traversal control (depth, symlinks, fs boundaries) -----------
category {
  dotted_path: "flags.traversal"
  paths: "fd --max-depth"
  paths: "fd --min-depth"
  paths: "fd --exact-depth"
  paths: "fd --follow"
  paths: "fd --one-file-system"
  paths: "fd --base-directory"
  paths: "fd --search-path"
}

# ---- Output formatting --------------------------------------------
# How results are printed: long listing, colors, hyperlinks, path
# separators, format strings, null-terminated output.
category {
  dotted_path: "flags.output"
  paths: "fd --absolute-path"
  paths: "fd --list-details"
  paths: "fd --print0"
  paths: "fd --color"
  paths: "fd --hyperlink"
  paths: "fd --format"
  paths: "fd --path-separator"
  paths: "fd --strip-cwd-prefix"
}

# ---- Result-set control & exit --------------------------------------
category {
  dotted_path: "flags.results"
  paths: "fd --max-results"
  paths: "fd --max-one-result"
  paths: "fd --quiet"
  paths: "fd --show-errors"
}

# ---- Command execution (-x / -X / --batch-size / --threads) -------
# fd's exec / exec-batch surface is declared via a clap builder-API
# Args struct (Exec); flags hidden from the derive table won't appear
# unless the adapter walks builder calls too. Threads + batch-size
# do come from the derive surface.
category {
  dotted_path: "flags.exec"
  paths: "fd --threads"
  paths: "fd --batch-size"
}

# ---- Positionals ---------------------------------------------------
# The two positionals: the search pattern and the optional root
# directories.
category {
  dotted_path: "positionals"
  paths: "fd <pattern>"
  paths: "fd <path>"
}
