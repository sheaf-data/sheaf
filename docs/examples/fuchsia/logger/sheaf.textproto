version: 1
project { name: "fuchsia" display_name: "Fuchsia OS — fuchsia.logger" }
scope { library: "fuchsia.logger" }
contract_anchor {
  name: "fidl"
  fidl { include: "sdk/fidl/**/*.fidl" exclude: "sdk/fidl/**/test/**" }
}
analyzer { name: "thin-reference" severity: WARNING }
surfaces_required: "docs.reference"
