# MonorepoManifest for the Fuchsia OS coverage index.
#
# Drives `sheaf scan --manifest docs/examples/fuchsia/manifest.textproto
#   --output-dir example-reports/fuchsia --repo /Volumes/T7/fuchsia`.
#
# 24 libraries across 8 domains. config_path resolves relative to this
# file's directory (docs/examples/fuchsia/); output resolves relative to
# --output-dir (example-reports/fuchsia/). Entries are ordered by the 8
# domains below; the index page itself re-sorts domains worst-first by
# median surface coverage (expected).

# === 1. Kernel & Zircon ===
entries {
  config_path: "zx/sheaf.textproto"
  library: "zx"
  ecosystem: "fidl"
  library_label: "zx"
  output: "zx/index.html"
  group: "Kernel & Zircon"
}
entries {
  config_path: "kernel/sheaf.textproto"
  library: "fuchsia.kernel"
  ecosystem: "fidl"
  library_label: "fuchsia.kernel"
  output: "kernel/index.html"
  group: "Kernel & Zircon"
}
entries {
  config_path: "boot/sheaf.textproto"
  library: "fuchsia.boot"
  ecosystem: "fidl"
  library_label: "fuchsia.boot"
  output: "boot/index.html"
  group: "Kernel & Zircon"
}

