# Sheaf config for scanning the cert-manager CRD contract surface.
#
# cert-manager ships its API as CustomResourceDefinition YAML in a single
# release bundle (cert-manager.crds.yaml). The `crd` contract-anchor
# adapter walks each CRD's spec.versions[].schema.openAPIV3Schema and
# emits:
#   - one TYPE per CRD kind (Certificate, Issuer, ClusterIssuer, ...)
#   - one CONFIG_KNOB per schema field (spec.renewBefore, ...)
#   - one LIBRARY per API group (cert-manager.io, acme.cert-manager.io)
#
# The doc join is free and mechanical: kubebuilder writes each field's Go
# doc comment into the OpenAPI `description`, so it ships inline in the
# same file. A field with an empty description is a real undocumented
# finding. No LLM, no cluster access, no template rendering.
#
# Prereq — fetch the CRD bundle into a scratch checkout (T7 recommended):
#   mkdir -p /Volumes/T7/sheaf-workspace/checkouts/crd-fixtures/cert-manager
#   curl -sSL -o \
#     /Volumes/T7/sheaf-workspace/checkouts/crd-fixtures/cert-manager/cert-manager.crds.yaml \
#     https://github.com/cert-manager/cert-manager/releases/download/v1.14.4/cert-manager.crds.yaml
#
# To run a scan + render the report:
#   go build -o sheaf ./cmd/sheaf
#   go build -o scanner ./cmd/scanner
#   cp docs/examples/cert-manager-crd-coverage-rules.textproto \
#      /Volumes/T7/sheaf-workspace/checkouts/crd-fixtures/categorization-rules.textproto
#   sheaf serve --config docs/examples/cert-manager-crd-coverage-config.textproto \
#               --repo /Volumes/T7/sheaf-workspace/checkouts/crd-fixtures --port 7810 &
#   scanner --server http://127.0.0.1:7810 --library cert-manager.io \
#           --ecosystem crd \
#           --repo-root /Volumes/T7/sheaf-workspace/checkouts/crd-fixtures \
#           --source-url-template \
#             "https://github.com/cert-manager/cert-manager/blob/v1.14.4/{path}#L{line}" \
#           -o example-reports/cert-manager-crd.html
#   kill %1
#
# --repo-root (same path as --repo) lets the scanner read source so the
# evidence panel renders. The report is scoped to Contract + Docs
# surfaces only: tests/examples/workflows are intentionally not shown —
# no such corpus is ingested for CRDs; the inline schema `description`
# is the doc surface.

version: 1

project {
  name: "cert-manager"
  display_name: "cert-manager (CRD API)"
  homepage: "https://cert-manager.io/docs/"
}

scope {
  library: "cert-manager.io"
}

contract_anchor {
  name: "crd"
  crd {
    # The release CRD bundle lives under cert-manager/. A single file
    # holds all six CRDs separated by `---`; non-CRD YAML is skipped
    # automatically (the adapter content-gates on
    # kind: CustomResourceDefinition).
    include: "cert-manager/**/*.yaml"
  }
}

analyzer { name: "thin-reference"      severity: WARNING }
analyzer { name: "documented-untested" severity: INFO }
analyzer { name: "tested-undocumented" severity: INFO }
