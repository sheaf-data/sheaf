# Source map for the kubectl CLI scan.
#
# Buckets kubectl subcommands using the same families kubectl --help
# itself uses (Basic Commands Beginner/Intermediate, Deploy, Cluster
# Management, Troubleshooting & Debugging, Advanced, Settings, and
# Other). Path patterns match against:
#   - YAML filenames in cobra.yaml_dir (kubectl_get.yaml,
#     kubectl_config_view.yaml)
#   - Markdown filenames in markdowncli.docs_dir
#     (kubectl_create_secret_docker-registry.md)
# so each pattern is written once and matches both ingest paths
# (kubectl's YAML and markdown both use the same kubectl_<sub>_<sub>
# leaf-filename convention).
#
# Update this list whenever kubectl grows a new top-level family; the
# default "docs.reference" bucket catches anything unmatched.

version: 1

category { dotted_path: "docs.reference" }

# ---- Basic (Beginner) ---------------------------------------------
# Day-1 commands: stand something up, expose it, change a setting.
category {
  dotted_path: "subcommands.basic"
  paths: "**/kubectl_create*"
  paths: "**/kubectl_expose*"
  paths: "**/kubectl_run*"
  paths: "**/kubectl_set*"
  paths: "**/kubectl_get*"
  paths: "**/kubectl_explain*"
  paths: "**/kubectl_edit*"
  paths: "**/kubectl_delete*"
}

# ---- Deploy --------------------------------------------------------
category {
  dotted_path: "subcommands.deploy"
  paths: "**/kubectl_rollout*"
  paths: "**/kubectl_scale*"
  paths: "**/kubectl_autoscale*"
}

# ---- Cluster management -------------------------------------------
category {
  dotted_path: "subcommands.cluster"
  paths: "**/kubectl_certificate*"
  paths: "**/kubectl_cluster-info*"
  paths: "**/kubectl_top*"
  paths: "**/kubectl_cordon*"
  paths: "**/kubectl_uncordon*"
  paths: "**/kubectl_drain*"
  paths: "**/kubectl_taint*"
}

# ---- Troubleshooting & debugging ----------------------------------
category {
  dotted_path: "subcommands.debug"
  paths: "**/kubectl_describe*"
  paths: "**/kubectl_logs*"
  paths: "**/kubectl_attach*"
  paths: "**/kubectl_exec*"
  paths: "**/kubectl_port-forward*"
  paths: "**/kubectl_proxy*"
  paths: "**/kubectl_cp*"
  paths: "**/kubectl_auth*"
  paths: "**/kubectl_debug*"
  paths: "**/kubectl_events*"
}

# ---- Advanced -----------------------------------------------------
# Declarative apply/patch flows + low-level config surgery.
category {
  dotted_path: "subcommands.advanced"
  paths: "**/kubectl_apply*"
  paths: "**/kubectl_diff*"
  paths: "**/kubectl_patch*"
  paths: "**/kubectl_replace*"
  paths: "**/kubectl_wait*"
  paths: "**/kubectl_kustomize*"
}

# ---- Settings (labels, annotations, shell completion) -------------
category {
  dotted_path: "subcommands.settings"
  paths: "**/kubectl_label*"
  paths: "**/kubectl_annotate*"
  paths: "**/kubectl_completion*"
}

# ---- kubeconfig manipulation --------------------------------------
# `kubectl config *` is a deep subcommand tree (~15 leaves) that
# deserves its own bucket; lumping it under "Other" obscures the
# coverage shape of cluster/user/context plumbing.
category {
  dotted_path: "subcommands.config"
  paths: "**/kubectl_config*"
}

# ---- Plugin surface -----------------------------------------------
category {
  dotted_path: "subcommands.plugin"
  paths: "**/kubectl_plugin*"
}

# ---- Discovery + version ------------------------------------------
category {
  dotted_path: "subcommands.discovery"
  paths: "**/kubectl_api-resources*"
  paths: "**/kubectl_api-versions*"
  paths: "**/kubectl_version*"
}

# ---- Root command -------------------------------------------------
# The standalone `kubectl` entry holds the global-options surface
# (every flag in `kubectl options`). Keeping it in its own bucket
# stops a single oversized row from skewing per-family coverage.
category {
  dotted_path: "subcommands.global"
  paths: "**/kubectl.yaml"
  paths: "**/kubectl.md"
}
