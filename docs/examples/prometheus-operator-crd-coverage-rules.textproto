# Source map for the Prometheus Operator CRD scan.
#
# Buckets elements by the CRD bundle file they come from — one file per
# resource family. The default "api.monitoring" bucket catches anything
# unmatched; the alerting/monitoring split keeps the per-family coverage
# shape legible.

version: 1

category { dotted_path: "api.monitoring" }

category {
  dotted_path: "api.alerting"
  paths: "**/*alertmanager*"
  paths: "**/*prometheusrules*"
  paths: "**/*thanosruler*"
}

category {
  dotted_path: "api.scraping"
  paths: "**/*servicemonitor*"
  paths: "**/*podmonitor*"
  paths: "**/*probe*"
}
