version: 1
project { name: "fuchsia" display_name: "Fuchsia OS — Hardware · Security & RTC" idl_prefix: "fuchsia" }
scope {}
contract_anchor {
  name: "fidl"
  fidl {
    include: "sdk/fidl/fuchsia.hardware.hrtimer/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.rtc/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.securemem/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.tee/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.tpmimpl/**/*.fidl"
    exclude: "sdk/fidl/**/test/**"
  }
}
doc_parser {
  name: "markdown"
  markdown {
    include: "docs/development/**/*.md"
    include: "docs/concepts/**/*.md"
    include: "docs/reference/fidl/**/*.md"
  }
}
test_parser {
  name: "gtest"
  gtest {
    include: "src/devices/rtc/**/*-test.cc"
    include: "src/devices/securemem/**/*-test.cc"
    include: "src/devices/tee/**/*-test.cc"
    include: "src/devices/tpm/**/*-test.cc"
  }
}
implements_map {
  name: "cpp-fidl-wireserver"
  include: "src/devices/rtc/**/*.cc"
  include: "src/devices/rtc/**/*.h"
  include: "src/devices/hrtimer/**/*.cc"
  include: "src/devices/hrtimer/**/*.h"
  include: "src/devices/securemem/**/*.cc"
  include: "src/devices/securemem/**/*.h"
  include: "src/devices/tee/**/*.cc"
  include: "src/devices/tee/**/*.h"
  include: "src/devices/tpm/**/*.cc"
  include: "src/devices/tpm/**/*.h"
}
analyzer { name: "thin-reference"      severity: WARNING }
analyzer { name: "documented-untested" severity: WARNING }
analyzer { name: "tested-undocumented" severity: INFO }
surfaces_required: "docs.reference"
surfaces_required: "docs.concepts"
