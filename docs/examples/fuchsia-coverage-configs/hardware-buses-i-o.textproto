version: 1
project { name: "fuchsia" display_name: "Fuchsia OS — Hardware · Buses & I/O" idl_prefix: "fuchsia" }
scope {}
contract_anchor {
  name: "fidl"
  fidl {
    include: "sdk/fidl/fuchsia.hardware.clock/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.clock.measure/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.clockimpl/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.dsp/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.gpio/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.hidbus/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.hidctl/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.i2c/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.i2c.businfo/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.i2cimpl/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.interconnect/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.pci/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.platform.bus/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.platform.device/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.registers/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.rpmb/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.scsi/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.sdhci/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.sdio/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.sdmmc/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.serial/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.serialimpl/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.sharedmemory/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.skipblock/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.sockettunnel/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.spi/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.spi.businfo/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.spiimpl/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.spmi/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.usb/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.usb.dci/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.usb.descriptor/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.usb.device/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.usb.endpoint/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.usb.function/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.usb.hci/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.usb.hcitest/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.usb.peripheral/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.usb.phy/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.usb.policy/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.usb.request/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.usb.tester/**/*.fidl"
    include: "sdk/fidl/fuchsia.hardware.usb.virtual.bus/**/*.fidl"
    exclude: "sdk/fidl/**/test/**"
  }
}
doc_parser {
  name: "markdown"
  markdown {
    include: "docs/development/**/*.md"
    include: "docs/concepts/**/*.md"
    include: "docs/reference/fidl/**/*.md"
  }
}
test_parser {
  name: "gtest"
  gtest {
    include: "src/devices/i2c/**/*-test.cc"
    include: "src/devices/spi/**/*-test.cc"
    include: "src/devices/gpio/**/*-test.cc"
    include: "src/devices/clock/**/*-test.cc"
    include: "src/devices/registers/**/*-test.cc"
    include: "src/devices/spmi/**/*-test.cc"
    include: "src/devices/serial/**/*-test.cc"
    include: "src/devices/usb/**/*-test.cc"
    include: "src/devices/pci/**/*-test.cc"
    include: "src/devices/bus/drivers/platform/**/*-test.cc"
    include: "src/devices/block/drivers/sdmmc/**/*-test.cc"
    include: "src/devices/block/drivers/aml-sdmmc/**/*-test.cc"
    include: "src/devices/block/drivers/sdhci/**/*-test.cc"
  }
}
implements_map {
  name: "cpp-fidl-wireserver"
  include: "src/devices/i2c/**/*.cc"
  include: "src/devices/i2c/**/*.h"
  include: "src/devices/spi/**/*.cc"
  include: "src/devices/spi/**/*.h"
  include: "src/devices/gpio/**/*.cc"
  include: "src/devices/gpio/**/*.h"
  include: "src/devices/clock/**/*.cc"
  include: "src/devices/clock/**/*.h"
  include: "src/devices/registers/**/*.cc"
  include: "src/devices/registers/**/*.h"
  include: "src/devices/spmi/**/*.cc"
  include: "src/devices/spmi/**/*.h"
  include: "src/devices/serial/**/*.cc"
  include: "src/devices/serial/**/*.h"
  include: "src/devices/usb/**/*.cc"
  include: "src/devices/usb/**/*.h"
  include: "src/devices/pci/**/*.cc"
  include: "src/devices/pci/**/*.h"
  include: "src/devices/bus/drivers/platform/**/*.cc"
  include: "src/devices/bus/drivers/platform/**/*.h"
  include: "src/devices/block/drivers/sdmmc/**/*.cc"
  include: "src/devices/block/drivers/sdmmc/**/*.h"
  include: "src/devices/block/drivers/aml-sdmmc/**/*.cc"
  include: "src/devices/block/drivers/aml-sdmmc/**/*.h"
  include: "src/devices/block/drivers/sdhci/**/*.cc"
  include: "src/devices/block/drivers/sdhci/**/*.h"
}
analyzer { name: "thin-reference"      severity: WARNING }
analyzer { name: "documented-untested" severity: WARNING }
analyzer { name: "tested-undocumented" severity: INFO }
surfaces_required: "docs.reference"
surfaces_required: "docs.concepts"
