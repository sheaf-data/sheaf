version: 1
project { name: "fuchsia" display_name: "Fuchsia OS — Session & Apps" idl_prefix: "fuchsia" }
scope {}
contract_anchor {
  name: "fidl"
  fidl {
    include: "sdk/fidl/fuchsia.session/**/*.fidl"
    include: "sdk/fidl/fuchsia.session.power/**/*.fidl"
    include: "sdk/fidl/fuchsia.session.scene/**/*.fidl"
    include: "sdk/fidl/fuchsia.session.window/**/*.fidl"
    exclude: "sdk/fidl/**/test/**"
  }
}
doc_parser {
  name: "markdown"
  markdown {
    include: "docs/development/**/*.md"
    include: "docs/concepts/**/*.md"
    include: "docs/reference/fidl/**/*.md"
  }
}
test_parser {
  name: "rust-test"
  rust_test {
    include: "src/session/bin/session_manager/**/*.rs"
    include: "src/ui/bin/scene_manager/**/*.rs"
  }
}
implements_map {
  name: "cpp-fidl-wireserver"
  include: "src/session/bin/session_manager/**/*.rs"
  include: "src/ui/bin/scene_manager/**/*.rs"
}
analyzer { name: "thin-reference"      severity: WARNING }
analyzer { name: "documented-untested" severity: WARNING }
analyzer { name: "tested-undocumented" severity: INFO }
surfaces_required: "docs.reference"
surfaces_required: "docs.concepts"
