version: 1
project { name: "fuchsia" display_name: "Fuchsia OS — Developer & Testing" idl_prefix: "fuchsia" }
scope {}
contract_anchor {
  name: "fidl"
  fidl {
    include: "sdk/fidl/fuchsia.developer.console/**/*.fidl"
    include: "sdk/fidl/fuchsia.developer.ffx.speedtest/**/*.fidl"
    include: "sdk/fidl/fuchsia.developer.ffxdaemonlifecycle/**/*.fidl"
    include: "sdk/fidl/fuchsia.developer.remotecontrol/**/*.fidl"
    include: "sdk/fidl/fuchsia.developer.tiles/**/*.fidl"
    include: "sdk/fidl/fuchsia.fdomain/**/*.fidl"
    include: "sdk/fidl/fuchsia.test/**/*.fidl"
    include: "sdk/fidl/fuchsia.test.manager/**/*.fidl"
    include: "sdk/fidl/fuchsia.testing.harness/**/*.fidl"
    include: "sdk/fidl/fuchsia.testing.runner/**/*.fidl"
    include: "sdk/fidl/fuchsia.testing.sl4f/**/*.fidl"
    exclude: "sdk/fidl/**/test/**"
  }
}
doc_parser {
  name: "markdown"
  markdown {
    include: "docs/development/**/*.md"
    include: "docs/concepts/**/*.md"
    include: "docs/reference/fidl/**/*.md"
  }
}
test_parser {
  name: "rust-test"
  rust_test {
    include: "src/sys/test_manager/**/*.rs"
    include: "src/developer/remote-control/**/*.rs"
  }
}
implements_map {
  name: "cpp-fidl-wireserver"
  include: "src/sys/test_manager/**/*.rs"
  include: "src/developer/remote-control/**/*.rs"
}
analyzer { name: "thin-reference"      severity: WARNING }
analyzer { name: "documented-untested" severity: WARNING }
analyzer { name: "tested-undocumented" severity: INFO }
surfaces_required: "docs.reference"
surfaces_required: "docs.concepts"
