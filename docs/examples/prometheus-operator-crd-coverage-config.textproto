# Sheaf config for scanning the Prometheus Operator CRD contract surface.
#
# Prometheus Operator ships its API as one CustomResourceDefinition YAML
# per resource family (monitoring.coreos.com_prometheuses.yaml,
# _alertmanagers.yaml, _servicemonitors.yaml, ...). The `crd`
# contract-anchor adapter walks each CRD's
# spec.versions[].schema.openAPIV3Schema and emits:
#   - one TYPE per CRD kind (Prometheus, Alertmanager, ServiceMonitor, ...)
#   - one CONFIG_KNOB per schema field (spec.replicas, spec.retention, ...)
#   - one LIBRARY for the monitoring.coreos.com API group
#
# The doc join is free and mechanical: each field's OpenAPI `description`
# (generated from the operator's Go doc comments) ships inline, so a
# documented field counts as covered and an undescribed field is a real
# undocumented finding. No LLM, no cluster access, no template rendering.
#
# Prereq — fetch the CRD bundle into a scratch checkout (T7 recommended):
#   mkdir -p /Volumes/T7/sheaf-workspace/checkouts/crd-fixtures/prometheus-operator
#   for c in alertmanagers prometheuses servicemonitors podmonitors probes \
#            prometheusrules thanosrulers alertmanagerconfigs; do
#     curl -sSL -o \
#       /Volumes/T7/sheaf-workspace/checkouts/crd-fixtures/prometheus-operator/monitoring.coreos.com_$c.yaml \
#       https://raw.githubusercontent.com/prometheus-operator/prometheus-operator/v0.72.0/example/prometheus-operator-crd/monitoring.coreos.com_$c.yaml
#   done
#
# To run a scan + render the report:
#   go build -o sheaf ./cmd/sheaf
#   go build -o scanner ./cmd/scanner
#   cp docs/examples/prometheus-operator-crd-coverage-rules.textproto \
#      /Volumes/T7/sheaf-workspace/checkouts/crd-fixtures/categorization-rules.textproto
#   sheaf serve --config docs/examples/prometheus-operator-crd-coverage-config.textproto \
#               --repo /Volumes/T7/sheaf-workspace/checkouts/crd-fixtures --port 7811 &
#   scanner --server http://127.0.0.1:7811 --library monitoring.coreos.com \
#           --ecosystem crd \
#           --repo-root /Volumes/T7/sheaf-workspace/checkouts/crd-fixtures \
#           --source-url-template \
#             "https://github.com/prometheus-operator/prometheus-operator/blob/v0.72.0/example/prometheus-operator-crd/{path}#L{line}" \
#           -o example-reports/prometheus-operator-crd.html
#   kill %1
#
# --repo-root (same path as --repo) lets the scanner read source so the
# evidence panel renders. The report is scoped to Contract + Docs
# surfaces only: tests/examples/workflows are intentionally not shown —
# no such corpus is ingested for CRDs; the inline schema `description`
# is the doc surface.

version: 1

project {
  name: "prometheus-operator"
  display_name: "Prometheus Operator (CRD API)"
  homepage: "https://prometheus-operator.dev/"
}

scope {
  library: "monitoring.coreos.com"
}

contract_anchor {
  name: "crd"
  crd {
    # All Prometheus Operator CRDs live under prometheus-operator/.
    # Non-CRD YAML is content-gated out by the adapter.
    include: "prometheus-operator/**/*.yaml"
  }
}

analyzer { name: "thin-reference"      severity: WARNING }
analyzer { name: "documented-untested" severity: INFO }
analyzer { name: "tested-undocumented" severity: INFO }
