# Sheaf config for scanning sharkdp/fd — the canonical clap-derive
# Rust CLI example.
#
# Joins the clap-derived contract surface (1 binary + ~48 flags,
# switches, positionals, config knobs) against:
#   - README.md + doc/*.md for documentation claims (markdown adapter)
#   - tests/tests.rs for test coverage (rust-test adapter)
#
# Why fd: clap's derive API (`#[derive(Parser)]`, `#[derive(Args)]`,
# `#[derive(Subcommand)]`) is the most common shape for modern Rust
# CLIs, and fd has a single self-contained crate with all flags in
# one file (src/cli.rs). Smaller and cleaner than alacritty, bat, eza,
# or gitui for showcasing what the adapter does.
#
# Prereqs (T7 is the recommended location):
#   git clone --depth=1 https://github.com/sharkdp/fd.git \
#     /Volumes/T7/sheaf-workspace/checkouts/fd
#
# To run a scan:
#   ln -sf /Users/.../sheaf.data/docs/examples/fd-coverage-config.textproto \
#     /Volumes/T7/sheaf-workspace/checkouts/fd/sheaf.textproto
#   ln -sf /Users/.../sheaf.data/docs/examples/fd-coverage-rules.textproto \
#     /Volumes/T7/sheaf-workspace/checkouts/fd/categorization-rules.textproto
#   sheaf doctor --repo /Volumes/T7/sheaf-workspace/checkouts/fd
#   sheaf scan   --repo /Volumes/T7/sheaf-workspace/checkouts/fd
#
# To browse interactively:
#   sheaf serve --repo /Volumes/T7/sheaf-workspace/checkouts/fd --port 7800 &
#   scanner --server http://127.0.0.1:7800 --library fd \
#           --ecosystem cli -o fd-report.html
#   kill %1

version: 1
project {
  name: "fd"
  display_name: "fd"
  homepage: "https://github.com/sharkdp/fd"
}

scope {
  library: "fd"
}

contract_anchor {
  name: "clap"
  clap {
    # fd is a single-crate project: Cargo.toml at the repo root, all
    # CLI definitions in src/cli.rs. Scanning "." catches the root
    # Parser struct directly. The crate-root basename ("fd-…")
    # never reaches the adapter because the in-source
    # `#[command(name = "fd")]` on Opts wins.
    crate_roots: "."
    # Default include "**/*.rs" + default exclude "**/target/**"
    # are correct for fd; no override needed.
  }
}

doc_parser {
  name: "markdown"
  markdown {
    # fd's user-facing prose lives in two places: the top-level
    # README.md (How-To, Pattern syntax, Excluding files, …) and the
    # CHANGELOG.md (release notes per version, often the only place
    # a flag's behavior change is described). Both reference flags
    # by their long names (`--hidden`, `--no-ignore`, …) which the
    # body-level token matcher picks up as DocClaim attributions.
    include: "README.md"
    include: "CHANGELOG.md"
    include: "doc/**/*.md"
    # SECURITY.md / CONTRIBUTING.md are governance docs, not flag
    # reference material. Excluded so they don't dilute attribution.
    exclude: "SECURITY.md"
    exclude: "CONTRIBUTING.md"
  }
}

# fd's integration tests live in tests/tests.rs and use the standard
# `#[test]` attribute. The rust-test adapter extracts one TestCase
# per function. Attribution to specific flags is name-token based:
# a `fn test_no_ignore_parent()` attributes to fd --no-ignore-parent
# via the body-parsing matcher.
test_parser {
  name: "rust-test"
  rust_test {
    include: "tests/**/*.rs"
    # Test helpers (testenv/) define fixtures and a `fd()` invocation
    # shim — they aren't tests themselves. Excluded so they don't
    # surface as zero-attribution noise.
    exclude: "tests/testenv/**"
  }
}

analyzer { name: "thin-reference"      severity: WARNING }
analyzer { name: "documented-untested" severity: INFO }
analyzer { name: "tested-undocumented" severity: INFO }

# fd is a single-binary CLI whose conceptual documentation lives
# in README.md (Pattern syntax, Excluding files, How fd handles
# ignore files, …) and whose change-log narrative lives in
# CHANGELOG.md. It does NOT ship an examples/ directory, an
# examples site, or tutorials — those are not surfaces fd has
# committed to. Declaring surfaces_required explicitly makes the
# masthead's "% bridged" compute against the surfaces fd actually
# ships, instead of penalising fd for the absence of "worked
# examples" it never promised. Without this declaration the
# default 3-surface bridged definition (concept + tests +
# examples) reads 0 of 44 bridged on a project where 41 of 44
# flags have both prose and test coverage.
surfaces_required: "docs.concepts"
surfaces_required: "tests"
