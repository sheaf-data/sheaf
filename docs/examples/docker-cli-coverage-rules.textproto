# Source map for the docker CLI scan.
#
# Buckets docker subcommands into top-level command families so the
# coverage report groups by area (container, image, volume, network,
# compose, etc.). Path patterns match against:
#   - Markdown filenames in dockerdoc.docs_dir (container_run.md, run.md)
#   - YAML filenames in cobra.yaml_dir (docker_container_run.yaml)
# So most patterns are listed in both forms (with and without the
# `docker_` prefix) to catch both ingest paths.
#
# Update this list whenever docker grows a new top-level family; the
# default "docs.reference" bucket catches anything unmatched.

version: 1

category { dotted_path: "docs.reference" }

category {
  dotted_path: "subcommands.container"
  paths: "**/container_*"
  paths: "**/docker_container_*"
  paths: "**/run.md"
  paths: "**/exec.md"
  paths: "**/ps.md"
  paths: "**/start.md"
  paths: "**/stop.md"
  paths: "**/restart.md"
  paths: "**/kill.md"
  paths: "**/rm.md"
  paths: "**/logs.md"
  paths: "**/top.md"
  paths: "**/stats.md"
  paths: "**/attach.md"
  paths: "**/cp.md"
  paths: "**/diff.md"
  paths: "**/export.md"
  paths: "**/inspect.md"
  paths: "**/pause.md"
  paths: "**/unpause.md"
  paths: "**/port.md"
  paths: "**/rename.md"
  paths: "**/update.md"
  paths: "**/wait.md"
  paths: "**/commit.md"
  paths: "**/create.md"
}

category {
  dotted_path: "subcommands.image"
  paths: "**/image_*"
  paths: "**/docker_image_*"
  paths: "**/images.md"
  paths: "**/build.md"
  paths: "**/pull.md"
  paths: "**/push.md"
  paths: "**/tag.md"
  paths: "**/rmi.md"
  paths: "**/history.md"
  paths: "**/save.md"
  paths: "**/load.md"
  paths: "**/import.md"
  paths: "**/search.md"
}

category {
  dotted_path: "subcommands.volume"
  paths: "**/volume_*"
  paths: "**/docker_volume_*"
}

category {
  dotted_path: "subcommands.network"
  paths: "**/network_*"
  paths: "**/docker_network_*"
}

category {
  dotted_path: "subcommands.system"
  paths: "**/system_*"
  paths: "**/docker_system_*"
  paths: "**/info.md"
  paths: "**/version.md"
  paths: "**/events.md"
  paths: "**/login.md"
  paths: "**/logout.md"
}

category {
  dotted_path: "subcommands.compose"
  paths: "**/compose_*"
  paths: "**/docker_compose_*"
}

category {
  dotted_path: "subcommands.buildx"
  paths: "**/buildx_*"
  paths: "**/docker_buildx_*"
  paths: "**/bake.md"
  paths: "**/builder*"
}

category {
  dotted_path: "subcommands.context"
  paths: "**/context_*"
  paths: "**/docker_context_*"
}

category {
  dotted_path: "subcommands.plugin"
  paths: "**/plugin_*"
  paths: "**/docker_plugin_*"
  paths: "**/manifest_*"
  paths: "**/docker_manifest_*"
  paths: "**/trust_*"
  paths: "**/docker_trust_*"
}

category {
  dotted_path: "subcommands.swarm"
  paths: "**/swarm_*"
  paths: "**/docker_swarm_*"
  paths: "**/service_*"
  paths: "**/docker_service_*"
  paths: "**/node_*"
  paths: "**/docker_node_*"
  paths: "**/stack_*"
  paths: "**/docker_stack_*"
  paths: "**/secret_*"
  paths: "**/docker_secret_*"
  paths: "**/config_*"
  paths: "**/docker_config_*"
}
