# Sheaf config for scanning a RENDERED ingress-nginx manifest surface.
#
# This exercises the k8smanifest contract-anchor adapter — the universal
# fallback for charts that ship no schema. It parses plain / rendered
# Kubernetes manifests (valid YAML ONLY, e.g. the output of
# `helm template`). It does NOT parse raw Helm templates; rendering is
# the user's `helm template` step, outside Sheaf.
#
# For each Kubernetes object document the adapter emits:
#   - one LIBRARY per API group   (apps, core, rbac.authorization.k8s.io, ...)
#   - one TYPE per resource kind  (Deployment, Service, ...)
#   - one CONFIG_KNOB per field actually present in the manifest
#     (spec.replicas, spec.template.spec.containers[].image, ...)
#
# Unlike CRDs, a rendered manifest carries no inline field documentation,
# so every field is reported as a real surface element and the doc side
# decides whether it is documented. Findings are mechanically derived
# (no LLM). Ecosystem = "manifest" (never "kubernetes").
#
# This report scopes to the `apps` API group — the chart's Deployment,
# the richest nested surface in the rendered stream (pod template,
# containers[], probes, volume mounts, ...).
#
# Prereq — render the chart into a scratch checkout (helm required;
# T7 recommended). The rendered YAML is the adapter's input, NOT the
# chart templates:
#   helm repo add ingress-nginx https://kubernetes.github.io/ingress-nginx
#   helm repo update
#   mkdir -p /Volumes/T7/sheaf-workspace/checkouts/manifest-fixtures/ingress-nginx
#   helm template ingress-nginx ingress-nginx/ingress-nginx --version 4.15.1 \
#     > /Volumes/T7/sheaf-workspace/checkouts/manifest-fixtures/ingress-nginx/rendered.yaml
#
# To run a scan + render the report:
#   go build -o sheaf ./cmd/sheaf
#   go build -o scanner ./cmd/scanner
#   cp docs/examples/ingress-nginx-manifest-coverage-rules.textproto \
#      /Volumes/T7/sheaf-workspace/checkouts/manifest-fixtures/categorization-rules.textproto
#   sheaf serve --config docs/examples/ingress-nginx-manifest-coverage-config.textproto \
#               --repo /Volumes/T7/sheaf-workspace/checkouts/manifest-fixtures --port 7812 &
#   scanner --server http://127.0.0.1:7812 --library apps \
#           --ecosystem manifest \
#           --repo-root /Volumes/T7/sheaf-workspace/checkouts/manifest-fixtures \
#           -o example-reports/ingress-nginx-manifest.html
#   kill %1
#
# --repo-root (same path as --repo) lets the scanner read source so the
# evidence panel renders. The report is scoped to Contract + Docs
# surfaces only: tests/examples/workflows are intentionally not shown —
# no such corpus is ingested for rendered manifests. (Manifests carry no
# inline field docs, so the Docs surface is expectedly sparse.)

version: 1

project {
  name: "ingress-nginx"
  display_name: "ingress-nginx (rendered manifest)"
  homepage: "https://kubernetes.github.io/ingress-nginx/"
}

scope {
  library: "apps"
}

contract_anchor {
  name: "k8smanifest"
  k8s_manifest {
    # The rendered manifest stream lives under ingress-nginx/. Documents
    # lacking apiVersion + kind are skipped automatically.
    include: "ingress-nginx/**/*.yaml"
  }
}

analyzer { name: "thin-reference"      severity: WARNING }
analyzer { name: "documented-untested" severity: INFO }
analyzer { name: "tested-undocumented" severity: INFO }
