/* validation chip popovers (native) */
(function(){
  function vpop(){var p=document.getElementById('vpop');if(!p){p=document.createElement('div');p.id='vpop';p.className='vpop';document.body.appendChild(p);}return p;}
  function vaway(e){var p=document.getElementById('vpop');if(p&&p.style.display==='block'&&!p.contains(e.target)&&!e.target.classList.contains('vchip')){p.style.display='none';document.removeEventListener('mousedown',vaway);}}
  document.addEventListener('keydown',function(e){if(e.key==='Escape'){var p=document.getElementById('vpop');if(p)p.style.display='none';}});
  function vsec(k,v){return v?('<div class="vk">'+k+'</div><div class="vv">'+v+'</div>'):'';}
  document.querySelectorAll('.vchip').forEach(function(ch){ch.addEventListener('click',function(e){
    e.stopPropagation();var p=vpop();var d=ch.dataset;
    p.innerHTML='<span class="vx" title="close">×</span>'
      +'<div class="vph"><span class="vbadge '+d.vc+'">'+d.vg+' '+d.vd+'</span> <b>'+d.vs+'</b></div>'
      +vsec('The number',d.vnum)+vsec('Provenance',d.vprov)+vsec('Issues',d.viss)+vsec('Remediation',d.vrem);
    p.style.display='block';
    var r=ch.getBoundingClientRect();
    p.style.top=(r.bottom+window.scrollY+8)+'px';
    p.style.left=Math.max(8,Math.min(r.left+window.scrollX,window.scrollX+document.documentElement.clientWidth-p.offsetWidth-12))+'px';
    p.querySelector('.vx').onclick=function(){p.style.display='none';};
    setTimeout(function(){document.addEventListener('mousedown',vaway);},0);
  });});
})();
